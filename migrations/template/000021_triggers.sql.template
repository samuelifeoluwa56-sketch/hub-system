-- TEMPLATE — 000021_triggers.sql (per-business triggers)
--
-- Applied by scripts/bootstrapBusiness.js. Creates the functions
-- and triggers that enforce per-business business rules:
--   - journal entry balance check
--   - stock non-negative check
--   - invoice payment auto-update
--   - payslip totals recalculation
--   - and others
