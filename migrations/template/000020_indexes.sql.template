-- ============================================================
-- TEMPLATE — 000020_indexes.sql (per-business indexes)
--
-- Applied by scripts/bootstrapBusiness.js after the table templates
-- (000007 through 000019) have created the tables. These are the
-- performance-critical indexes that aren't inline with the CREATE
-- TABLE statements.
--
-- The SHARED SCHEMA section of 000020 is NOT in this template —
-- those run once via the main migration; per-business runs would
-- be redundant.
-- ============================================================


-- products
-- NOTE: to_tsvector is STABLE not IMMUTABLE so it cannot appear in a
--       WHERE predicate. GIN expression indexes (no WHERE) are fine.
CREATE INDEX IF NOT EXISTS idx_j_products_name
  ON {{BUSINESS}}.products USING GIN (to_tsvector('english', name));

CREATE INDEX IF NOT EXISTS idx_j_products_price_range
  ON {{BUSINESS}}.products (selling_price, is_active)
  WHERE is_deleted = false;

CREATE INDEX IF NOT EXISTS idx_j_products_reorder
  ON {{BUSINESS}}.products (reorder_level)
  WHERE is_active = true AND is_deleted = false;

-- stock_movements — most queried table in the system
CREATE INDEX IF NOT EXISTS idx_j_stock_type_date
  ON {{BUSINESS}}.stock_movements (movement_type, performed_at DESC);

CREATE INDEX IF NOT EXISTS idx_j_stock_from_loc
  ON {{BUSINESS}}.stock_movements (from_location_id, performed_at DESC)
  WHERE from_location_id IS NOT NULL;

-- stock_reservations
CREATE INDEX IF NOT EXISTS idx_j_reservations_contact
  ON {{BUSINESS}}.stock_reservations (reserved_for)
  WHERE reserved_for IS NOT NULL AND status = 'active';

-- crm_deals
CREATE INDEX IF NOT EXISTS idx_j_deals_close_date
  ON {{BUSINESS}}.crm_deals (expected_close_date)
  WHERE is_deleted = false AND stage NOT IN ('won', 'lost');

CREATE INDEX IF NOT EXISTS idx_j_deals_value
  ON {{BUSINESS}}.crm_deals (expected_value DESC)
  WHERE is_deleted = false;

-- quotations
CREATE INDEX IF NOT EXISTS idx_j_quotations_expiry
  ON {{BUSINESS}}.quotations (valid_until, status)
  WHERE status IN ('draft', 'sent', 'viewed');

-- sales_orders
CREATE INDEX IF NOT EXISTS idx_j_orders_outstanding
  ON {{BUSINESS}}.sales_orders (amount_outstanding DESC)
  WHERE amount_outstanding > 0;

-- invoices
CREATE INDEX IF NOT EXISTS idx_j_invoices_overdue
  ON {{BUSINESS}}.invoices (due_date, status)
  WHERE status = 'overdue' AND is_deleted = false;

CREATE INDEX IF NOT EXISTS idx_j_invoices_period
  ON {{BUSINESS}}.invoices (issue_date DESC)
  WHERE is_deleted = false;

-- invoice_payments
CREATE INDEX IF NOT EXISTS idx_j_payments_date
  ON {{BUSINESS}}.invoice_payments (payment_date DESC);

CREATE INDEX IF NOT EXISTS idx_j_payments_confirmed
  ON {{BUSINESS}}.invoice_payments (is_confirmed, created_at DESC)
  WHERE is_confirmed = false;

-- journal_entries
CREATE INDEX IF NOT EXISTS idx_j_je_period_type
  ON {{BUSINESS}}.journal_entries (reference_type, entry_date DESC);

-- journal_lines — P&L queries hit this constantly
CREATE INDEX IF NOT EXISTS idx_j_jl_debit_credit
  ON {{BUSINESS}}.journal_lines (account_id, debit, credit);

-- bank_statements
CREATE INDEX IF NOT EXISTS idx_j_bs_date_amount
  ON {{BUSINESS}}.bank_statements (transaction_date DESC, amount);

-- purchase_orders
CREATE INDEX IF NOT EXISTS idx_j_po_date
  ON {{BUSINESS}}.purchase_orders (order_date DESC)
  WHERE is_deleted = false;

CREATE INDEX IF NOT EXISTS idx_j_po_expected_del
  ON {{BUSINESS}}.purchase_orders (expected_delivery, status)
  WHERE status IN ('sent', 'acknowledged', 'partially_received');

-- goods_received
CREATE INDEX IF NOT EXISTS idx_j_gr_date
  ON {{BUSINESS}}.goods_received (received_date DESC);

-- supplier_invoices
CREATE INDEX IF NOT EXISTS idx_j_sup_inv_due
  ON {{BUSINESS}}.supplier_invoices (due_date, status)
  WHERE status IN ('pending', 'matched', 'approved');

-- expenses
CREATE INDEX IF NOT EXISTS idx_j_expenses_date
  ON {{BUSINESS}}.expenses (expense_date DESC);

-- payroll_runs
CREATE INDEX IF NOT EXISTS idx_j_payroll_period
  ON {{BUSINESS}}.payroll_runs (period_year, period_month);

-- payslips
CREATE INDEX IF NOT EXISTS idx_j_payslips_period
  ON {{BUSINESS}}.payslips (run_id, net_salary DESC);

-- commission_earned
CREATE INDEX IF NOT EXISTS idx_j_commission_period
  ON {{BUSINESS}}.commission_earned (period_year, period_month, profile_id);

-- retail_partners
CREATE INDEX IF NOT EXISTS idx_j_partners_active
  ON {{BUSINESS}}.retail_partners (is_active, arrangement_type);

CREATE INDEX IF NOT EXISTS idx_j_partners_balance
  ON {{BUSINESS}}.retail_partners (current_balance DESC)
  WHERE is_active = true;

-- consignment_stock
CREATE INDEX IF NOT EXISTS idx_j_consignment_date
  ON {{BUSINESS}}.consignment_stock (sent_date DESC, status);

-- deliveries
CREATE INDEX IF NOT EXISTS idx_j_deliveries_date
  ON {{BUSINESS}}.deliveries (created_at DESC);

CREATE INDEX IF NOT EXISTS idx_j_deliveries_active
  ON {{BUSINESS}}.deliveries (status, courier)
  WHERE status NOT IN ('delivered', 'returned', 'failed');

-- delivery_tracking
CREATE INDEX IF NOT EXISTS idx_j_tracking_source
  ON {{BUSINESS}}.delivery_tracking (source, occurred_at DESC);

-- campaigns
CREATE INDEX IF NOT EXISTS idx_j_campaigns_type
  ON {{BUSINESS}}.campaigns (campaign_type, status);

-- campaign_recipients
CREATE INDEX IF NOT EXISTS idx_j_recipients_status
  ON {{BUSINESS}}.campaign_recipients (status, campaign_id);

-- loyalty_points
CREATE INDEX IF NOT EXISTS idx_j_loyalty_type
  ON {{BUSINESS}}.loyalty_points (transaction_type, created_at DESC);

CREATE INDEX IF NOT EXISTS idx_j_loyalty_expires
  ON {{BUSINESS}}.loyalty_points (expires_at)
  WHERE expires_at IS NOT NULL;

-- pos_transactions
CREATE INDEX IF NOT EXISTS idx_j_pos_tx_date
  ON {{BUSINESS}}.pos_transactions (created_at DESC);

CREATE INDEX IF NOT EXISTS idx_j_pos_tx_served_date
  ON {{BUSINESS}}.pos_transactions (served_by, created_at DESC);

-- pos_sessions
CREATE INDEX IF NOT EXISTS idx_j_pos_sess_date
  ON {{BUSINESS}}.pos_sessions (opened_at DESC);