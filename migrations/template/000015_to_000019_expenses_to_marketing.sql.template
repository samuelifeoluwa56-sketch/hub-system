CREATE TABLE {{BUSINESS}}.consignment_stock (
  consignment_id        UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  partner_id            UUID        NOT NULL REFERENCES {{BUSINESS}}.retail_partners (partner_id),
  product_id            UUID        NOT NULL REFERENCES {{BUSINESS}}.products (product_id),
