# ============================================================
# Hub Platform — Environment Variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local or .env.production to git.
# ============================================================

NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=hub_db
PG_USER=hub_app
PG_PASSWORD=CHANGE_ME
PG_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
# to generate a secure JWT secret, use;
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_MIN_64_CHARS
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_STRING
JWT_REFRESH_EXPIRY=7d

# ── Storage ───────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
# For S3:
# STORAGE_DRIVER=s3
# S3_BUCKET=hub-platform-files
# S3_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Paystack ──────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=sk_test_CHANGE_ME
PAYSTACK_SECRET_KEY=sk_test_CHANGE_ME
PAYSTACK_WEBHOOK_SECRET=CHANGE_ME

# ── Flutterwave ───────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWSECK_TEST_CHANGE_ME
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-CHANGE_ME
FLUTTERWAVE_WEBHOOK_SECRET=CHANGE_ME

# ── Shopify (if connected) ────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=

# ── WooCommerce (if connected) ────────────────────────────
WC_SITE_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_WEBHOOK_SECRET=

# ── Meta (Instagram + Facebook) ──────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=CHANGE_ME_RANDOM
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# ── TikTok ────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── YouTube ───────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── WhatsApp Business ─────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_RANDOM

# ── Chowdeck ──────────────────────────────────────────────
CHOWDECK_API_KEY=
CHOWDECK_BASE_URL=https://api.chowdeck.com

# ── GIGL ─────────────────────────────────────────────────
GIGL_CLIENT_ID=
GIGL_CLIENT_SECRET=
GIGL_BASE_URL=https://api.gigl.com

# ── SMTP ──────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourbrand.com
SMTP_PASS=CHANGE_ME
SMTP_FROM_NAME=Hub Platform
SMTP_FROM_EMAIL=noreply@yourbrand.com
